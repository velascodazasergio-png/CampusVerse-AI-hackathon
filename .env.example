# ═══════════════════════════════════════
#  CampusVerse AI — Variables de entorno
#  Copia este archivo como .env y rellena
# ═══════════════════════════════════════

# Puerto del servidor Node.js
PORT=3000

# OpenAI API Key (opcional — si no la tienes el Mentor IA usa respuestas locales)
# Consíguela en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# URL de Webhook (Make, Zapier, n8n) — opcional
WEBHOOK_URL=
